# Copy to `.env` in the repo root and set secrets. Do not commit `.env`.
# Fal image/video services read only these env vars (no hardcoded model IDs in Python).

FAL_API_KEY=
FAL_IMAGE_MODEL=fal-ai/nano-banana-2
# Pipeline VideoAgent defaults to image-to-video; optional text-to-video smoke: scripts/fal_text_to_video_smoke.py
FAL_T2V_MODEL=fal-ai/kling-video/v2.6/pro/text-to-video
FAL_VIDEO_MODEL=fal-ai/kling-video/v2.6/pro/image-to-video
FAL_TTS_MODEL=fal-ai/minimax/speech-02-turbo

# VideoAgent backend: fal (default) or wavespeed (WaveSpeed.ai / UniVA-compatible T2V+I2V)
# FW_VIDEO_BACKEND=fal
# WAVESPEED_API_KEY=
# WAVESPEED_VIDEO_PROVIDER=bytedance
# WAVESPEED_VIDEO_T2V_MODEL=seedance-v1-pro-t2v-480p
# WAVESPEED_VIDEO_I2V_MODEL=seedance-v1-pro-i2v-480p
# WAVESPEED_VIDEO_ASPECT_RATIO=16:9
